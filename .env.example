# ==============================================================================
# EURI API CONFIGURATION - EXAMPLE TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in your actual keys.
# DO NOT commit real keys to version control!

# Database Data Cleaning
DB_EURI_API_KEY=your-api-key-here
DB_CLEANING_MODEL=gemini-2.5-pro

# Uploaded File Data Cleaning
UPLOAD_EURI_API_KEY=your-api-key-here
UPLOAD_CLEANING_MODEL=gpt-5-mini-2025-08-07

# API Data Cleaning
API_EURI_API_KEY=your-api-key-here
API_CLEANING_MODEL=gemini-2.0-flash

# Fallback Model (used when primary model fails)
FALLBACK_EURI_API_KEY=your-api-key-here
FALLBACK_MODEL=gpt-4.1-mini

# EURI API Base URL
EURI_API_BASE_URL=https://api.euron.one/api/v1/euri

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Format: postgresql+psycopg2://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB_NAME]
DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@[HOST]:[PORT]/postgres

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000

# ==============================================================================
# AUTHENTICATION CONFIGURATION
# ==============================================================================
JWT_SECRET_KEY=generate_a_random_secure_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==============================================================================
# DISTRIBUTED TASK QUEUE (REDIS/CELERY)
# ==============================================================================
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379
